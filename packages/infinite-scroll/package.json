{
  "name": "@zhenzichao/vue2-infinite-scroll",
  "version": "0.1.1",
  "description": "A lightweight infinite scroll component plugin for Vue 2 - page scroll load more data with IntersectionObserver",
  "main": "dist/infinite-scroll.js",
  "module": "dist/infinite-scroll.mjs",
  "exports": {
    ".": {
      "import": "./dist/infinite-scroll.mjs",
      "require": "./dist/infinite-scroll.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "keywords": [
    "infinite-scroll",
    "lazy-load",
    "pagination",
    "vue2",
    "component",
    "intersection-observer"
  ],
  "author": "zhenzichao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:itzhenzichao/vue2-plugins.git"
  },
  "peerDependencies": {
    "vue": "^2.7.14"
  },
  "devDependencies": {
    "vite": "^4.5.14",
    "vue-template-compiler": "2.7.14",
    "vite-plugin-vue2": "^2.0.3",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  }
}